-- Configurações
local MAX_RETRIES = 3  -- Número máximo de tentativas se um script falhar
local RETRY_DELAY = 1  -- Delay entre tentativas (segundos)

-- Função para carregar um script com tratamento de erros
local function loadScriptSafely(url, scriptName)
    for attempt = 1, MAX_RETRIES do
        local success, result = pcall(function()
            return game:HttpGet(url, true)
        end)
        
        if success then
            local loadSuccess, loadResult = pcall(loadstring, result)
            if loadSuccess then
                loadResult()
                warn("✅ Script carregado com sucesso:", scriptName or url)
                return true
            else
                warn("⚠️ Erro ao executar script", scriptName or url, "| Tentativa", attempt, "/", MAX_RETRIES)
                warn("Erro:", loadResult)
            end
        else
            warn("⚠️ Falha ao baixar script", scriptName or url, "| Tentativa", attempt, "/", MAX_RETRIES)
            warn("Erro:", result)
        end
        
        if attempt < MAX_RETRIES then
            task.wait(RETRY_DELAY)
        end
    end
    return false
end

-- Banner de inicialização profissional
local function showBanner()
    print("\n" .. string.rep("=", 50))
    print("🚀 GAME HUB PROFISSIONAL")
    print("📊 Game ID: " .. game.GameId)
    print("🎮 Place ID: " .. game.PlaceId)
    print("👤 Player: " .. game.Players.LocalPlayer.Name)
    print("📅 " .. os.date("%d/%m/%Y %H:%M:%S"))
    print(string.rep("=", 50) .. "\n")
end

local startTime = tick()

-- Função principal
local function main()
    showBanner()
    
    local gameId = game.GameId
    local gameScripts = scripts[gameId]
    
    if gameScripts then
        warn("🎮 Jogo detectado! Carregando scripts...")
        
        -- Contador de scripts carregados
        local loadedCount = 0
        
        -- Carrega todos os scripts para este jogo
        for i, scriptUrl in ipairs(gameScripts) do
            warn(string.format("📦 Carregando script %d/%d...", i, #gameScripts))
            
            if loadScriptSafely(scriptUrl, "Script " .. i) then
                loadedCount = loadedCount + 1
            end
            
            -- Pequeno delay entre scripts para evitar sobrecarga
            if i < #gameScripts then
                task.wait(0.2)
            end
        end
        
        -- Resumo
        if loadedCount > 0 then
            warn(string.format("✅ %d/%d scripts carregados com sucesso!", loadedCount, #gameScripts))
        else
            warn("❌ Nenhum script pôde ser carregado")
        end
        
    else
        warn("⚠️ Jogo não suportado pelo hub")
        
        -- FALLBACK: Injeta Infinite Yield quando o jogo não é suportado
        warn("🔄 Carregando Infinite Yield como fallback...")
        loadScriptSafely("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source", "Infinite Yield (Fallback)")
    end
    
    -- Mensagem final
    print("\n🎯 Hub inicializado com sucesso!")
    print("⏱️  Tempo de inicialização: " .. tostring(tick() - startTime):sub(1, 5) .. "s")
end

-- Inicialização com tratamento de erros
local success, err = pcall(main)

if not success then
    warn("❌ Erro crítico no hub:")
    warn(err)
    print("🔄 Tente reiniciar o jogo")
end